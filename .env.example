# 4cs environment template. Copy to `.env` and fill in your token.
# The daemon loads `.env` then `.env.local` from the project root at startup.

# --- Authentication -------------------------------------------------------
# 4casters session token. The daemon reports `token_needed` until this is set.
# Account reads and trading calls are disabled without it. Catalog polling
# (public orderbook) also requires a valid token.
FOURCASTER_AUTH_TOKEN=

# The daemon also accepts 4CASTER_AUTH_TOKEN and VITE_AUTH_TOKEN as aliases.

# --- Safety ---------------------------------------------------------------
# LIVE=0 (default) => no place/cancel/edit is ever submitted upstream; those
# commands return a dry-run preview instead. LIVE=1 enables real API writes.
LIVE=0

# Hard cap (stake units) enforced by the daemon before any live placement.
MAX_BET=5

# --- API ------------------------------------------------------------------
FOURCASTER_API_BASE_URL=https://api.4casters.io
FOURCASTER_AUTH_SCHEME=bearer

# --- Streaming ------------------------------------------------------------
# Enabled by default when a token is present. Set 0 to run REST reconciliation
# only. Market/orderbook events and account order events are recorded in
# state/tape-YYYY-MM-DD.jsonl; state.json exposes connection and replay health.
FOURCASTER_STREAMING=1

# Optional comma-separated price-feed league filters. With this blank, 4cs uses
# the active leagues from the REST bootstrap (and watched game IDs).
FOURCASTER_STREAM_LEAGUES=

# --- Runtime directories (relative paths resolve against the project root) -
# State snapshot, and the file-based IPC mailbox the CLI talks to the daemon
# through. Defaults shown; override for a system-wide install.
FOURCASTER_STATE_DIR=./state
FOURCASTER_COMMANDS_DIR=./commands
FOURCASTER_RESPONSES_DIR=./responses

# --- Poll intervals (ms) --------------------------------------------------
POLL_ORDERBOOK_MS=8000
POLL_BALANCE_MS=5000
POLL_ORDERS_MS=5000
POLL_POSITIONS_MS=30000

# Exchange-settlement accounting is deliberately slow and does not affect the
# eight-second orderbook cadence. The daemon journals a rolling two-day P&L snapshot.
POLL_SETTLEMENT_MS=3600000

# Optional account-wide dead-man switch. 0 disables it (default); values >5
# cancel every open order on this account if daemon heartbeats stop.
FOURCASTER_HEARTBEAT_SEC=0

# --- Fees (optional) ------------------------------------------------------
# Taker commission as a fraction of winnings (maker/post pays none). Used only
# for local exposure math; does not affect what is sent to the exchange.
COMMISSION_TAKER_RATE=0.01
